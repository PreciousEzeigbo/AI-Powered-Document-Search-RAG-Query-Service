# API Keys
# Get your Google API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Get your OpenRouter API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Choose which provider to use
USE_GOOGLE=false
PROVIDER=openrouter

# Model Configuration
EMBEDDING_MODEL=google/text-embedding-004
LLM_MODEL=google/gemini-1.5-flash

# Vector Store Configuration
VECTOR_STORE_TYPE=chromadb
COLLECTION_NAME=document_chunks

# Database
DATABASE_PATH=rag_documents.db

# Document Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=50

# API Configuration
API_TITLE=RAG Document Search Service
API_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
RELOAD=true

# RAG Configuration
DEFAULT_MAX_RESULTS=5
MAX_MAX_RESULTS=20
RAG_TEMPERATURE=0.3
RAG_MAX_TOKENS=1000

# --- Security & Privacy Settings ---

# API access key (optional). When set, all requests must include this key
# via X-API-Key header or Bearer token. Strongly recommended for production.
API_ACCESS_KEY=

# Session TTL in hours. Documents and embeddings belonging to expired sessions
# are automatically purged. Set to 0 to disable automatic cleanup.
SESSION_TTL_HOURS=24

# Rate limiting (using slowapi format: "count/period")
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_QUERY=30/minute
